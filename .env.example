# Quran App Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration (optional - uses defaults)
# NEXT_PUBLIC_QURAN_API_URL=https://api.alquran.cloud/v1
# NEXT_PUBLIC_AUDIO_BASE_URL=https://cdn.islamic.network/quran_audio/256

# Analytics (optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Feature Flags (optional)
# NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
# NEXT_PUBLIC_ENABLE_SHARING=true
# NEXT_PUBLIC_ENABLE_BOOKMARKS=true

# Development
# NODE_ENV=development
